#!/bin/sh

echo "[1/4] Copy files to $HOME"
mkdir -p $HOME/.config/fastfetch
cp .config/fastfetch/config.jsonc $HOME/.config/fastfetch/config.jsonc

echo "[2/4] Copying read-only files to host using su"

su -c "mkdir -p /etc/fastfetch && cp etc/fastfetch/E-logo.txt /etc/fastfetch/E-logo.txt && cp etc/nanorc /etc/nanorc"

su -c 'cat > /usr/bin/enuxfetch << EOF
#!/bin/sh
exec fastfetch
EOF
chmod +x /usr/bin/enuxfetch'

echo "[3/4] Installing XWallpaper and setting up the wallpaper"

su -c "apt install -y xwallpaper -q"

mkdir -p "$HOME/.local/share/walls"
cp walls/ENux.png "$HOME/.local/share/walls/ENux.png"

WALL="$HOME/.local/share/walls/ENux.png"

mkdir -p "$HOME/.config/autostart"

cat > "$HOME/.config/autostart/xwallpaper.desktop" << EOF
[Desktop Entry]
Type=Application
Name=Wallpaper
Exec=xwallpaper --zoom $WALL
X-GNOME-Autostart-enabled=true
EOF

xwallpaper --zoom "$WALL"

echo "[4/4] Done"
sleep 0.45
exit 0
