#!/bin/sh
set -e

# Operate relative to this script's own location, not the caller's cwd. The
# installer runs us from the user's home, so relative `cp etc/...` paths would
# otherwise miss.
cd "$(dirname "$0")"

# Escalate only when we are not already root.
if [ "$(id -u)" -eq 0 ]; then
    run_root() { "$@"; }
else
    run_root() { sudo "$@"; }
fi

echo "[*] Installing fastfetch config and nanorc"
run_root mkdir -p /etc/fastfetch
run_root cp etc/fastfetch/E-logo.txt   /etc/fastfetch/E-logo.txt
run_root cp etc/fastfetch/config.jsonc /etc/fastfetch/config.jsonc
run_root cp etc/nanorc                 /etc/nanorc

echo "[*] Installing enuxfetch helper"
run_root sh -c 'printf "#!/bin/sh\nexec fastfetch\n" > /usr/bin/enuxfetch && chmod +x /usr/bin/enuxfetch'

# Per-user, so this stays as the invoking user (no run_root). Uncomment to use.
#
# echo "[*] Installing xwallpaper and setting the wallpaper"
# run_root apt install -y -q xwallpaper
#
# mkdir -p "$HOME/.local/share/walls"
# cp walls/ENux.jpg "$HOME/.local/share/walls/ENux.jpg"
# WALL="$HOME/.local/share/walls/ENux.jpg"
#
# mkdir -p "$HOME/.config/autostart"
# cat > "$HOME/.config/autostart/xwallpaper.desktop" << EOF
# [Desktop Entry]
# Type=Application
# Name=Wallpaper
# Exec=xwallpaper --zoom $WALL
# X-GNOME-Autostart-enabled=true
# EOF
#
# xwallpaper --zoom "$WALL"

echo "[*] Done"
exit 0
