#/bin/sh

echo "[1/3] Copy files to $HOME"
mkdir -p $HOME/.config/fastfetch
cp .config/fastfetch/config.jsonc $HOME/.config/fastfetch/config.jsonc

echo "[2/3] Copying read-only files to host using su"

su -c "mkdir /etc/fastfetch -p && cp etc/fastfetch/E-logo.txt /etc/fastfetch/E-logo.txt && cp etc/nanorc /etc/nanorc"

su -c 'cat > /usr/bin/enuxfetch << EOF
#!/bin/sh
exec fastfetch
EOF
chmod +x /usr/bin/enuxfetch'

echo "[3/3] Done"
sleep 0.45
exit 0
